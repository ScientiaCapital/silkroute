# SilkRoute Environment Variables
# Copy to .env and fill in your API keys

# ============================================================
# PRIMARY: OpenRouter (recommended — single key for all models)
# ============================================================
SILKROUTE_OPENROUTER_API_KEY=

# ============================================================
# OPTIONAL: Direct provider keys (bypass OpenRouter for lower latency)
# ============================================================
SILKROUTE_DEEPSEEK_API_KEY=
SILKROUTE_QWEN_API_KEY=
SILKROUTE_GLM_API_KEY=
SILKROUTE_MOONSHOT_API_KEY=

# ============================================================
# LOCAL INFERENCE (Mac Studio / NVIDIA Spark)
# ============================================================
SILKROUTE_OLLAMA_ENABLED=false
SILKROUTE_OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# HARDWARE PROFILE: mac-mini | mac-studio | nvidia-spark | hetzner-vps |
#                   raspberry-pi | custom
# Drives fit-to-hardware model routing: profiles with a local RAM budget
# (mac-mini 16GB, mac-studio 64GB, nvidia-spark 128GB) run FREE/STANDARD work
# on a local Ollama model that fits; raspberry-pi / hetzner-vps / custom have a
# 0GB budget and delegate ALL inference to the cloud. PREMIUM always escalates
# to the cloud. An Ubuntu edge box with >=16GB can use mac-mini (or mac-studio
# at >=64GB) — the budget is what matters, not the literal machine.
# ============================================================
SILKROUTE_HARDWARE_PROFILE=mac-mini

# ============================================================
# MCP BRIDGE: openav-mcp (epiphan-openav-bridge) — live room control
# The AV control plane for lecture-capture / live-event rooms (Pearl + EC20).
# Read-only by default; set MUTATING=true to enable device control (PTZ moves,
# preset recall, recording start/stop).
# ============================================================
SILKROUTE_MCP_OPENAV_ENABLED=false
# Absolute path to openav-mcp's own venv python:
SILKROUTE_MCP_OPENAV_COMMAND=/path/to/epiphan-openav-bridge/openav-mcp/.venv/bin/python
SILKROUTE_MCP_OPENAV_MUTATING=false
# JSON array of device records the agent addresses by alias. Use YOUR devices'
# IPs and credentials (and change the EC20's factory-default admin/admin!):
SILKROUTE_MCP_OPENAV_DEVICES=[{"alias":"room-pearl","host":"192.168.1.100","username":"admin","password":"<pearl-pw>","kind":"pearl"},{"alias":"room-cam","host":"192.168.1.101","username":"admin","password":"<ec20-pw>","kind":"ec20"}]
SILKROUTE_MCP_OPENAV_ORCHESTRATOR_URL=http://localhost:8080
SILKROUTE_MCP_OPENAV_PEARL_URL=http://localhost:8081
SILKROUTE_MCP_OPENAV_EC20_URL=http://localhost:8082

# ============================================================
# API SECURITY (required before exposing the API publicly)
# ============================================================
# environment=production makes the API refuse to start with an empty API key.
SILKROUTE_ENVIRONMENT=development
# Bearer token for the REST API. Empty = auth disabled (local dev only).
# MUST be set to a strong secret in production.
SILKROUTE_API_KEY=
# demo_mode=true disables money-spending endpoints (/runtime/invoke,
# /runtime/stream, POST /tasks) so a public try-it deployment can't drain budget.
SILKROUTE_API_DEMO_MODE=false

# ============================================================
# OPTIONAL: model-finops telemetry (fire-and-forget usage reporting)
# Reports each agent iteration's usage to model-finops's
# POST /api/telemetry/ingest. Opt-in — off unless ENABLED=true.
# ============================================================
SILKROUTE_FINOPS_ENABLED=false
SILKROUTE_FINOPS_BASE_URL=http://localhost:8000
SILKROUTE_FINOPS_TOKEN=              # must match model-finops's FINOPS_INGEST_TOKEN
SILKROUTE_FINOPS_TIMEOUT_SECONDS=3.0
