# SilkRoute Environment Variables
# Copy to .env and fill in your API keys

# ============================================================
# PRIMARY: OpenRouter (recommended — single key for all models)
# ============================================================
SILKROUTE_OPENROUTER_API_KEY=

# ============================================================
# OPTIONAL: Direct provider keys (bypass OpenRouter for lower latency)
# ============================================================
SILKROUTE_DEEPSEEK_API_KEY=
SILKROUTE_QWEN_API_KEY=
SILKROUTE_GLM_API_KEY=
SILKROUTE_MOONSHOT_API_KEY=

# ============================================================
# LOCAL INFERENCE (Mac Studio / NVIDIA Spark)
# ============================================================
SILKROUTE_OLLAMA_ENABLED=false
SILKROUTE_OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# HARDWARE PROFILE: mac-mini | mac-studio | nvidia-spark | hetzner-vps
# ============================================================
SILKROUTE_HARDWARE_PROFILE=mac-mini

# ============================================================
# API SECURITY (required before exposing the API publicly)
# ============================================================
# environment=production makes the API refuse to start with an empty API key.
SILKROUTE_ENVIRONMENT=development
# Bearer token for the REST API. Empty = auth disabled (local dev only).
# MUST be set to a strong secret in production.
SILKROUTE_API_KEY=
# demo_mode=true disables money-spending endpoints (/runtime/invoke,
# /runtime/stream, POST /tasks) so a public try-it deployment can't drain budget.
SILKROUTE_API_DEMO_MODE=false

# ============================================================
# OPTIONAL: model-finops telemetry (fire-and-forget usage reporting)
# Reports each agent iteration's usage to model-finops's
# POST /api/telemetry/ingest. Opt-in — off unless ENABLED=true.
# ============================================================
SILKROUTE_FINOPS_ENABLED=false
SILKROUTE_FINOPS_BASE_URL=http://localhost:8000
SILKROUTE_FINOPS_TOKEN=              # must match model-finops's FINOPS_INGEST_TOKEN
SILKROUTE_FINOPS_TIMEOUT_SECONDS=3.0
